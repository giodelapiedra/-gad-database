generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ENCODER
}

enum Status {
  ACTIVE
  PENDING
  INACTIVE
}

enum UploadStatus {
  SUCCESS
  PARTIAL
  FAILED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ENCODER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  records          Record[]
  uploadLogs       UploadLog[]
  files            File[]
  resourceFolders  ResourceFolder[] @relation("resourceFolders")
  resourceFiles    ResourceFile[]   @relation("resourceFiles")

  @@map("users")
}

model Department {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  color     String
  head      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  records    Record[]
  uploadLogs UploadLog[]
  files      File[]

  @@map("departments")
}

model Record {
  id           String   @id @default(cuid())
  name         String
  departmentId String
  year         Int
  status       Status   @default(ACTIVE)
  data         Json     @default("{}")
  uploadedById String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  uploadedBy User       @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([departmentId])
  @@index([year])
  @@index([departmentId, year])
  @@map("records")
}

model UploadLog {
  id           String       @id @default(cuid())
  departmentId String
  year         Int
  fileName     String
  inserted     Int          @default(0)
  skipped      Int          @default(0)
  uploadedById String
  status       UploadStatus @default(SUCCESS)
  errors       Json         @default("[]")
  createdAt    DateTime     @default(now())

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  uploadedBy User       @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([departmentId])
  @@map("upload_logs")
}

model File {
  id           String   @id @default(cuid())
  fileName     String
  originalName String
  size         Int
  mimeType     String
  departmentId String
  year         Int
  uploadedById String
  createdAt    DateTime @default(now())

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  uploadedBy User       @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([departmentId])
  @@index([departmentId, year])
  @@map("files")
}

model ResourceFolder {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  createdById String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  parent   ResourceFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children ResourceFolder[] @relation("FolderTree")
  files    ResourceFile[]
  createdBy User            @relation("resourceFolders", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([parentId])
  @@index([deletedAt])
  @@map("resource_folders")
}

model ResourceFile {
  id           String   @id @default(cuid())
  fileName     String
  originalName String
  size         Int
  mimeType     String
  folderId     String?
  uploadedById String
  createdAt    DateTime @default(now())
  deletedAt    DateTime?

  folder     ResourceFolder? @relation(fields: [folderId], references: [id], onDelete: Cascade)
  uploadedBy User            @relation("resourceFiles", fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([folderId])
  @@index([deletedAt])
  @@map("resource_files")
}

model DownloadLog {
  id           String   @id @default(cuid())
  fileType     String   // "resource" or "department"
  fileId       String
  fileName     String
  name         String
  location     String
  contactNo    String
  organization String
  sex          String   // "MALE" or "FEMALE"
  age          Int
  ip           String?
  createdAt    DateTime @default(now())

  @@index([fileType])
  @@index([createdAt])
  @@index([fileId])
  @@map("download_logs")
}
